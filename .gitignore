# --- Tests / coverage ---
.tox/
.nox/
.coverage
.coverage.*
.cache
htmlcov/
.pytest_cache/
*.cover

# --- IDE ---
.idea/
.vscode/
.cursorignore
.cursorindexingignore
.ruff_cache/
.mypy_cache/
.dmypy.json
.pyre/
.pytype/
cython_debug/

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- DVC (si utilisé plus tard) ---
# /data.dvc
# .dvc/tmp/

# ================================================================
# EXCEPTIONS — ne jamais ignorer ces fichiers
# ================================================================
!**/README.md
!**/.gitkeep
!configs/**/*.yaml
!experiments/**/results*/*.json
!experiments/**/figures/*.png
!experiments/**/figures/*.svg
!docs/**/*.png
!docs/**/*.svg
!docs/**/*.mmd
!docs/**/*.pdf
!deployments/docker/*.Dockerfile
!deployments/docker/docker-compose.yml

# Keep official US1 deployment bundle for microservices runtime
!experiments/fl-iot-ids-v3/outputs/deployment/
!experiments/fl-iot-ids-v3/outputs/deployment/baseline_fedavg_normal_classweights/
!experiments/fl-iot-ids-v3/outputs/deployment/baseline_fedavg_normal_classweights/**
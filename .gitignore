*.py[codz]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.installed.cfg
.pdm-python
.pdm-build/
.pixi/
__pypackages__/

# --- Environments ---
.env
.envrc
services/.env
services/mosquitto/passwords
.venv/
.venv.zip
venv/
env/
ENV/

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb_checkpoints

# --- ML / FL Artifacts (JAMAIS versionnés) ---
*.npz
*.npy
*.pkl
*.h5
*.hdf5
*.safetensors
*.msgpack
*.pt
*.pth
*.onnx

# --- Datasets & données réseau (JAMAIS versionnés) ---
*.csv
*.arff
*.parquet
*.pcap
*.pcapng
*.pcap.csv
*.zip
*.tar.gz
*.gz
*.7z


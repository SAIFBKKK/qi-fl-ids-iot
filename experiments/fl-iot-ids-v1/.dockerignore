node_modules/

# =========================
# Keep required runtime assets
# =========================
# Do NOT ignore:
# - src/
# - configs/
# - artifacts/
# - data/processed/
# - pyproject.toml
# - requirements.txt
# - requirements-lock.txt
# - README.md
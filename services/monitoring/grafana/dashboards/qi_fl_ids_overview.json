  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "refresh": "10s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["qi-fl-ids", "overview"],
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "title": "QI-FL-IDS Overview",
  "uid": "qi-fl-ids-overview",
  "version": 1,
  "weekStart": "",
  "templating": {
    "list": []
  },
  "panels": [
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 3},
      "id": 1,
      "options": {"colorMode": "value", "graphMode": "area"},
      "targets": [{"expr": "registered_nodes_total", "refId": "A"}],
      "title": "Nodes registered",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 3},
      "id": 2,
      "targets": [{"expr": "fl_active_clients", "refId": "A"}],
      "title": "Active FL clients",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 3},
      "id": 3,
      "targets": [{"expr": "fl_current_round", "refId": "A"}],
      "title": "Current FL round",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {"unit": "none", "decimals": 3},
        "overrides": []
      },
      "gridPos": {"x": 18, "y": 0, "w": 6, "h": 3},
      "id": 4,
      "targets": [{"expr": "fl_f1_macro", "refId": "A"}],
      "title": "F1-macro",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {"unit": "ops"},
        "overrides": []
      },
      "gridPos": {"x": 0, "y": 3, "w": 12, "h": 8},
      "id": 5,
      "targets": [
        {
          "expr": "rate(ids_predictions_total[1m])",
          "legendFormat": "{{node_id}}",
          "refId": "A"
        }
      ],
      "title": "IDS predictions / sec by node",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {"unit": "opm"},
        "overrides": []
      },
      "gridPos": {"x": 12, "y": 3, "w": 12, "h": 8},
      "id": 6,
      "targets": [
        {
          "expr": "rate(ids_alerts_total[1m]) * 60",
          "legendFormat": "{{node_id}}",
          "refId": "A"
        }
      ],
      "title": "IDS alerts / min by node",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {"unit": "ms"},
        "overrides": []
      },
      "gridPos": {"x": 0, "y": 11, "w": 12, "h": 8},
      "id": 7,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(inference_latency_seconds_bucket[1m])) by (le, node_id)) * 1000",
          "legendFormat": "{{node_id}}",
          "refId": "A"
        }
      ],
      "title": "Inference latency p95 (ms)",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "gridPos": {"x": 12, "y": 11, "w": 12, "h": 8},
      "id": 8,
      "targets": [
        {
          "expr": "registered_nodes_by_tier",
          "legendFormat": "{{tier}}",
          "refId": "A"
        }
      ],
      "title": "Nodes by tier",
      "type": "timeseries"
    }
  ]
}

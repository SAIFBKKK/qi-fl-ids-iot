# Replay configuration
REPLAY_RATE=5
REPLAY_SCENARIO=mixed_chaos
DATASET_DIR=/data/demo

# MQTT credentials
NODE_ID=node1
MQTT_BROKER=mosquitto
MQTT_PORT=1883
MQTT_USERNAME=ids_user
MQTT_PASSWORD=changeme_in_dotenv

# FL configuration
FL_SERVER_HOST=fl-server
FL_SERVER_PORT=8080
FL_NUM_ROUNDS=10
TRAINING_MODE=mock
REAL_FL_EXPERIMENT=exp_v4_multitier_fedavg_normal_classweights
REAL_FL_ROUNDS=1
REAL_FL_WORKDIR=/app/experiments/fl-iot-ids-v3

# Inference configuration
INFERENCE_THRESHOLD=0.5
MODEL_PATH=/artifacts/global_model.pth
SCALER_PATH=/artifacts/scaler.pkl
LABEL_MAPPING_PATH=/artifacts/label_mapping.json

# Observability
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
MLFLOW_PORT=5000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme_in_dotenv

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
